import torch
import os
from PIL import Image
import numpy as np
from diffusers import StableDiffusionImg2ImgPipeline, DDIMScheduler

class VanillaBaselineGenerator:
    def __init__(
        self,
        base_model_path: str = "models/sd15",
        device: str = "cuda",
        dtype: torch.dtype = torch.float16
    ):
        self.device = device
        self.dtype = dtype
        
        print(f"--- [Baseline] Step 1: Loading Original SD 1.5 Img2Img Pipeline ---")

        # 使用 Img2Img 管道，这样才能输入你的 init_image 进行公平对比
        self.pipe = StableDiffusionImg2ImgPipeline.from_pretrained(
            base_model_path,
            torch_dtype=dtype,
            safety_checker=None,
            requires_safety_checker=False
        ).to(device)
        
        print("Note: Running pure base model without LoRA.")
        
        # 调度器保持一致
        self.pipe.scheduler = DDIMScheduler.from_config(
            self.pipe.scheduler.config,
            rescale_betas_zero_snr=True,
            timestep_spacing="trailing"
        )
        print("Successfully loaded clean Vanilla SD 1.5.")

    @torch.inference_mode()
    def generate_baseline(
        self,
        image_path: str,
        prompt: str = "pure 1bit pixel art, black and white, monochrome, binarized, extremely sharp edges, white background",
        negative_prompt: str = "color, blurry, gray, lowres, soft, noisy",
        seed: int = 42
    ) -> Image.Image:
        
        # 预处理输入图（缩放到 8 的倍数）
        init_image = Image.open(image_path).convert("RGB")
        w, h = (init_image.size[0] // 8) * 8, (init_image.size[1] // 8) * 8
        init_image = init_image.resize((w, h))

        generator = torch.Generator(device=self.device).manual_seed(seed)
        
        # 运行原生生成
        # 注意：这里不传 control_image，不传 callback
        raw_result = self.pipe(
            prompt=prompt,
            negative_prompt=negative_prompt,
            image=init_image,
            strength=0.8,        # 与你原脚本强度保持一致
            num_inference_steps=30,
            guidance_scale=7.5,   # 原生模型推荐值
            generator=generator
        ).images[0]

        return raw_result

def run_batch_vanilla():
    # 路径配置
    base_dir = "/root/autodl-tmp/SD-pixelization-2"
    input_folder = os.path.join(base_dir, "input")
    output_folder = os.path.join(base_dir, "1bit/Vanilla")
    
    os.makedirs(output_folder, exist_ok=True)
    
    # 初始化
    gen = VanillaBaselineGenerator(
        base_model_path=f"{base_dir}/models/sd15"
    )
    
    # 获取 input 文件夹下所有图片
    image_files = [f for f in os.listdir(input_folder) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]
    print(f"Found {len(image_files)} images to process.")

    for img_file in sorted(image_files):
        print(f"Processing Baseline for -> {img_file}")
        img_path = os.path.join(input_folder, img_file)
        
        try:
            # 生成原生对照组图像
            res = gen.generate_baseline(image_path=img_path, seed=42)
            
            # 保存，文件名保持一致
            res.save(os.path.join(output_folder, img_file))
        except Exception as e:
            print(f"Error processing {img_file}: {e}")

if __name__ == "__main__":
    run_batch_vanilla()
