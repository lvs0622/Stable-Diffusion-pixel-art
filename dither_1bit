import os
from PIL import Image

def run_dithering_baseline():
    # 路径配置
    base_dir = "/root/autodl-tmp/SD-pixelization-2"
    input_folder = os.path.join(base_dir, "input")
    output_folder = os.path.join(base_dir, "1bit/Dither_Baseline")
    
    # 创建输出目录
    if not os.path.exists(output_folder):
        os.makedirs(output_folder)

    # 获取所有图片
    image_files = [f for f in os.listdir(input_folder) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]
    print(f"Found {len(image_files)} images for Dithering baseline.")

    for img_file in image_files:
        img_path = os.path.join(input_folder, img_file)
        
        # 1. 加载并转为灰度
        img = Image.open(img_path).convert("RGB")
        
        # 2. 调用 Floyd-Steinberg 抖动算法
        # PIL 的 convert("1") 默认使用的就是 Floyd-Steinberg 
        dithered = img.convert("1")
        
        # 3. 转回 RGB 方便统一保存和后续排版
        res = dithered.convert("RGB")
        
        # 保存结果
        res.save(os.path.join(output_folder, img_file))
        print(f"Dithered -> {img_file}")

if __name__ == "__main__":
    run_dithering_baseline()
